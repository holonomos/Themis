# Themis — dnsmasq configuration
# Generated from inventory — DO NOT HAND-EDIT
#
# Authoritative DNS + DHCP for the OOB management network.
# DNS:  hostname.{{ domain }} -> management IP for all {{ reservations|length }} nodes.
# DHCP: MAC reservations for every dhcp-mode node ({{ dhcp_reservations|length }} leases).

# --- General ---
domain={{ domain }}
local=/{{ domain }}/
expand-hosts
no-resolv
bogus-priv
bind-interfaces
interface=eth-mgmt

# --- Upstream DNS (for guests that escape the lab domain) ---
server=1.1.1.1
server=8.8.8.8

# --- DNS entries (hostname -> management IP, all nodes) ---
{% for res in reservations %}
address=/{{ res.name }}.{{ domain }}/{{ res.ip }}
{% endfor %}

# --- DHCP: pool + MAC-pinned reservations ---
# Pool covers the dynamic tail of the mgmt subnet; known MACs always get
# their deterministic IP via dhcp-host regardless of pool bounds.
dhcp-range={{ dhcp_pool_start }},{{ dhcp_pool_end }},12h
dhcp-option=option:dns-server,{{ services_ip }}
dhcp-option=option:domain-search,{{ domain }}
{% for rsv in dhcp_reservations %}
dhcp-host={{ rsv.mac }},{{ rsv.name }},{{ rsv.ip }}
{% endfor %}

# --- Logging ---
log-queries
log-dhcp
