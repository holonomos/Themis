# Themis — Prometheus configuration
# Generated from topology.yml — DO NOT HAND-EDIT
#
# Scrape targets:
#   - FRR VMs on port 9342 (frr_exporter)
#   - all VMs on port 9100 (node_exporter)

global:
  scrape_interval: {{ scrape_interval }}s
  evaluation_interval: {{ scrape_interval }}s

rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:

  # --- FRR routing containers (frr_exporter sidecar) ---
  - job_name: 'frr'
    static_configs:
{% for target in frr_targets %}
      - targets: ['{{ target.ip }}:{{ target.port }}']
        labels:
          instance: '{{ target.name }}'
          role: '{{ target.role }}'
{% if target.rack %}
          rack: '{{ target.rack }}'
{% endif %}
{% endfor %}

  # --- VM nodes (node_exporter) ---
  - job_name: 'node'
    static_configs:
{% for target in vm_targets %}
      - targets: ['{{ target.ip }}:{{ target.port }}']
        labels:
          instance: '{{ target.name }}'
          role: '{{ target.role }}'
{% if target.rack %}
          rack: '{{ target.rack }}'
{% endif %}
{% endfor %}
