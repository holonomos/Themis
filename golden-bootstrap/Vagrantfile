# frozen_string_literal: true
# Themis — single VM for interactive golden-image creation.
# User passes a base .box (or sets THEMIS_VAGRANT_BOX), runs bake.sh,
# SSHs in and installs what the lab needs, then `bake.sh --package` packages it.

Vagrant.configure("2") do |config|
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # Give the guest enough time to get a DHCP lease on the vagrant-libvirt
  # management network.  The default 300 s is too short on slow hosts.
  config.vm.boot_timeout = 600

  box_name = ENV.fetch("THEMIS_VAGRANT_BOX", "themis-golden-base")
  mem = (ENV["THEMIS_STRAP_MEM"] || "4096").to_i
  cpus = (ENV["THEMIS_STRAP_CPUS"] || "2").to_i

  config.vm.define "golden-strap", primary: true do |vm|
    vm.vm.box = box_name
    vm.vm.hostname = "golden-strap"

    vm.vm.provider :libvirt do |libvirt|
      libvirt.driver = "kvm"
      libvirt.storage_pool_name = "default"
      libvirt.memory = mem
      libvirt.cpus = cpus
      libvirt.mgmt_attach = true
    end
  end
end
